Project:
  id: 'alert_sms_telegram'
  stg: 'local' #prd:正式區  dev:測試區  local:個人本地端
  idx: 'alert_sms_telegram_logs'
Check_friday:
  check_url: 'https://ailog/getget'
  try_cnt: 3
  try_sleep: 30 # 30 sec
  monitored_hosts: # a host is unhealthy when a reason is appended after its name
    - host_a
    - host_b
    - host_c
Check_wednesday:
  check_url: 'https://options/info' # f_options
  check_url1: 'https://options/is_trading_time' # f_options
  check_url2: 'https://options/get_strategy_quote' # f_options
  CRON_DATETIME_THRESHOLD_SEC: 30  # Maximum allowed time difference in seconds
  OnOrderBook_datetime_THRESHOLD_SEC: 30  # Maximum allowed time difference in seconds
  if_check_MEM: True
  MEM_AVAIL_THRESHOLD_PERCENT: 10.0  # Minimum allowed memory availability in percent
  try_cnt: 3
  try_sleep: 5 # sec
  auth_tokens:
    - 'Basic XXXXX='
  monitored_strategies: # per-strategy quote freshness checked during trading hours
    - NEAR
    - FARR
    - FTXO
SMS:
  sms_cmd: 'curl -k -s -o /dev/null -X POST https://api.telegram.org/botXXX:YYY/sendMessage -d chat_id=ZZZ '
  # sms_cmd: 'curl -k -s -o /dev/null -X POST https://api.telegram.org/botXXX:YYY/sendMessage -d chat_id=ZZZ -d text="alert!text!"'
